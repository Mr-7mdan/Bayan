# Backend configuration
APP_ENV=dev
CORS_ORIGINS=http://localhost:3000
SECRET_KEY=change-me

# Local DuckDB store path
DUCKDB_PATH=.data/local.duckdb

# Optional Postgres DSN (format: postgresql+psycopg://user:pass@host:port/db)
POSTGRES_DSN=

# Optional Supabase Postgres DSN (format: postgresql+psycopg://user:pass@host:port/db)
SUPABASE_POSTGRES_DSN=

# Query rate limiting (token bucket). ON by default; set a value to 0 to disable
# that bucket. Defaults: per-user 5/s refill, burst 20; global 50/s refill, burst 100.
# A 20-widget dashboard load fits inside the per-user burst, so normal use never 429s.
QUERY_RATE_PER_SEC=5
QUERY_BURST=20
QUERY_RATE_GLOBAL_PER_SEC=50
QUERY_BURST_GLOBAL=100

# In-process buckets are PER WORKER: with gunicorn WORKERS=N the effective limit is
# N x the configured value. Set REDIS_URL to share buckets across workers (required
# for correct limits with run_prod_gunicorn.sh). Single-worker deployments
# (waitress, uvicorn --workers 1) do not need Redis.
# Example: redis://localhost:6379/0
REDIS_URL=
REDIS_PREFIX=ratelimit

# Result cache TTL (seconds) for common query results
RESULT_CACHE_TTL=15

# Per-actor in-flight concurrency cap for queries
USER_QUERY_CONCURRENCY=2

# Safety cap for query page size (LIMIT)
QUERY_MAX_LIMIT=10000
